# =============================================================================
# ManyMinds backend — environment template
# =============================================================================
# Copy this file to `.env` (in this same directory) and fill in only the
# integrations you actually want to enable. The backend is designed to boot
# with NO env file at all: every Azure/3rd-party service is optional and the
# app falls back to in-memory stubs (see app/services/stubs.py) so the whole
# frontend works end-to-end without any subscription.
#
# Each section below documents what filling in those keys turns on, and what
# the stub behaviour is when you leave them blank. Never commit a real .env.
# =============================================================================


# ----- Application
# Base process-level settings. APP_ENV switches log formatting / CORS strictness.
# FRONTEND_ORIGIN is the single allowed CORS origin — set this to your prod URL
# when deploying. LOG_LEVEL accepts the standard python logging names.
APP_NAME=ManyMinds
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000


# ----- Database — Azure Cosmos DB (NoSQL API)
# Required for live mode. Without these two values the app drops into stub
# mode (every endpoint serves canned data from app/services/stubs.py).
# COSMOS_BOOTSTRAP_CONTAINERS lets the app create the six containers on first
# boot — set false in prod after IaC has provisioned them. COSMOS_DEFAULT_RU
# is the per-container throughput used at bootstrap; set 0 to fall back to
# database-level shared throughput (cheaper for small workloads).
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-master-key>
COSMOS_DATABASE_NAME=manyminds
COSMOS_BOOTSTRAP_CONTAINERS=true
COSMOS_DEFAULT_RU=400


# ----- JWT auth
# JWT_SECRET MUST be set to a long random string in any deployment — if left
# blank a fresh secret is generated per process, which invalidates every
# refresh token on restart. Access tokens are short-lived; refresh tokens are
# rotated and stored in the auth_tokens container.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGO=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30


# ----- LLM — Azure OpenAI
# Powers council member responses, debate moderation, and game commentary.
# All four AZURE_OPENAI_* values must be set to bring the live client up;
# otherwise services/llm.py returns deterministic canned replies per persona.
# AZURE_OPENAI_DEPLOYMENT is the deployment name from the Azure portal (not
# the underlying model name, though they often coincide e.g. "gpt-4o-mini").
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_TEMPERATURE=0.85
AZURE_OPENAI_MAX_OUTPUT_TOKENS=512


# ----- Azure Computer Vision (Image Analysis 4.0)
# Enables describe_image / analyze_image_url so council members can react to
# images the user attaches to chat messages. Without these keys the image
# pipeline returns a generic placeholder caption.
AZURE_VISION_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_VISION_KEY=<your-azure-vision-key>


# ----- Azure AI Language (Text Analytics)
# Used for deterministic language detection (routing user input to the right
# preferred_language) and numeric sentiment scores (fed into the Neo4j memory
# graph as edge weights). Missing keys → language defaults to "en" and
# sentiment is skipped.
AZURE_LANGUAGE_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=<your-azure-language-key>


# ----- Azure Translator
# A separate Azure resource from Language. AZURE_TRANSLATOR_REGION is the
# Azure region the resource is deployed in (e.g. "eastus") and is required
# by the REST API even when using the global endpoint. Without these the
# translation step is a no-op and original text is passed through.
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_KEY=<your-azure-translator-key>
AZURE_TRANSLATOR_REGION=<your-azure-region>


# ----- Voice — ElevenLabs
# Drives both TTS (per-member streaming voice replies) and STT (voice input
# transcription). Without ELEVENLABS_API_KEY the /voice/synthesize endpoint
# returns 503 and the frontend transparently falls back to text-only mode.
# The five per-member voice IDs below point at well-known public ElevenLabs
# voices and are safe to ship as defaults; override per-member to use a
# specific cloned/branded voice.
ELEVENLABS_API_KEY=<your-elevenlabs-key>
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_VOICE_ARIA=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_REX=VR6AewLTigWG4xSOukaG
ELEVENLABS_VOICE_SAGE=TX3LPaxmHKxFdv7VOQHJ
ELEVENLABS_VOICE_NOVA=MF3mGyEYCl7XYWbV9V6O
ELEVENLABS_VOICE_ECHO=AZnzlk1XvdvUeBnXmlld


# ----- Neo4j — graph memory
# Long-term relational memory: entities, topics, sentiment edges built up
# from every chat / debate / game. When NEO4J_URI is unset the /memory/graph
# endpoint falls back to a deterministic per-user generator so the visualiser
# still has something to render. Typical URIs:
#   bolt://localhost:7687                 (local docker / standalone)
#   neo4j://localhost:7687                (single-instance with routing)
#   neo4j+s://xxxxx.databases.neo4j.io    (Neo4j Aura — cloud)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_DATABASE=neo4j


# ----- Email (transactional)
# Used for password reset links. Provider is auto-selected by which creds are
# present:
#   1. SENDGRID_API_KEY        → SendGrid HTTP API
#   2. SMTP_HOST + SMTP_USER   → SMTP (Postmark / Mailgun / Gmail / Resend / etc.)
#   3. nothing                 → Console provider — the reset token is printed
#                                to backend logs, so password reset still works
#                                end-to-end for local dev.
# APP_BASE_URL is the public URL of the frontend; reset links are built against it.
APP_BASE_URL=http://localhost:3000

SENDGRID_API_KEY=<your-sendgrid-api-key>

SMTP_HOST=<your-smtp-host>
SMTP_PORT=587
SMTP_USER=<your-smtp-username>
SMTP_PASSWORD=<your-smtp-password>
SMTP_STARTTLS=true
SMTP_USE_SSL=false

EMAIL_FROM=ManyMinds <no-reply@manyminds.local>
PASSWORD_RESET_TTL_MIN=30
