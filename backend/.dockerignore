# Keep the build context small and never ship secrets into the image.
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets — set these as Fly secrets / host env vars instead, never bake them in.
.env
.env.*
!.env.example
env-text.txt

# Local cruft
.git/
.gitignore
*.log
*.sqlite3
.DS_Store
README.md
AZURE_SETUP.md
